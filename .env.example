# Transcripcion local con Whisper instalado en tu ordenador.
# Tambien puedes cambiar comando y modelo desde Crear > Conectar con IA.
# Ejemplos:
# WHISPER_COMMAND=whisper
# WHISPER_COMMAND=python -m whisper
WHISPER_COMMAND=whisper
WHISPER_MODEL=base

# Procesado local de video y audio.
FFMPEG_COMMAND=ffmpeg

# Seguridad local.
# Limite maximo por archivo subido. Si no se define, la app usa 1024 MB.
APP_MAX_UPLOAD_MB=1024
# Mantener en false para uso local. En Vercel usa true solo junto con APP_ACCESS_SECRET.
APP_ALLOW_REMOTE_WRITE=false
# local usa data/app.json y public/uploads. drive usa Google Drive como fuente de verdad.
APP_STORAGE_DRIVER=local
# Clave privada personal para habilitar escrituras remotas con cookie firmada.
# Usa una frase larga aleatoria y no la subas a Git.
APP_ACCESS_SECRET=

# Worker local Drive-first. Usa APP_STORAGE_DRIVER=drive al ejecutarse y cachea artifacts aqui.
# Comando: npm.cmd run worker:local -- --once
# Para diagnostico sin Whisper instalado: npm.cmd run worker:local -- --once --skip-transcription
APP_WORKER_CACHE_DIR=data/worker-cache

# DeepSeek para analisis textual desde el panel Conectar con IA.
# No sustituye a Whisper local para transcribir audio.
DEEPSEEK_API_KEY=

# Ollama local para analizar con Qwen en este ordenador.
# Desde el panel puedes cambiar la URL y el comando de arranque, por defecto: ollama serve.
# Si Ollama usa el puerto por defecto, no hace falta tocarlo.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Google Drive con OAuth de usuario (no necesita Workspace de pago).
# Crea un OAuth Client ID en Google Cloud Console > APIs & Services > Credentials.
# Tipo: Web application. Redirect URI: http://localhost:3000/api/google/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
# Drive-first en Vercel necesita refresh token como variable de entorno.
# En local puedes omitirlo y usar data/google-drive-token.json, que esta ignorado por Git.
GOOGLE_OAUTH_REFRESH_TOKEN=
# Carpeta raiz donde se crea app-db/. Si se omite, se usa el ID guardado en los settings de Drive.
GOOGLE_DRIVE_ROOT_FOLDER_ID=
