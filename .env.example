# Transcripcion local con Whisper instalado en tu ordenador.
# Ejemplos:
# WHISPER_COMMAND=whisper
# WHISPER_COMMAND=python -m whisper
WHISPER_COMMAND=whisper
WHISPER_MODEL=base

# Procesado local de video y audio.
FFMPEG_COMMAND=ffmpeg

# Seguridad local.
# Limite maximo por archivo subido. Si no se define, la app usa 1024 MB.
APP_MAX_UPLOAD_MB=1024
# Mantener en false salvo que anadas autenticacion delante de la app.
APP_ALLOW_REMOTE_WRITE=false

# Transcripcion por API de OpenAI.
# Coste orientativo consultado el 21/05/2026:
# gpt-4o-mini-transcribe ~ $0.003/min
# gpt-4o-transcribe ~ $0.006/min
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Analisis opcional con IA para coaching textual extra.
OPENAI_ANALYSIS_MODEL=gpt-5-nano

# DeepSeek para analisis textual desde el panel Conexiones IA.
# No sustituye a Whisper/OpenAI para transcribir audio.
DEEPSEEK_API_KEY=

# Para el panel Conexiones IA tambien puedes usar proveedores economicos,
# endpoints compatibles, Anthropic, Google, Mistral o una API/proxy propio.
# En la UI se configura nombre, base URL, endpoints, autenticacion y modelos.
AI_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Google Drive con Service Account.
# Comparte la carpeta destino de Drive con el email de la service account.
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
