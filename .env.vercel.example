# Importar este archivo en Vercel > Environment Variables.
# Rellena los valores reales en Vercel, no los subas a GitHub.

# Drive-first: Vercel sirve la UI y escribe sesiones/jobs/artifacts en Google Drive.
APP_STORAGE_DRIVER=drive
APP_ALLOW_REMOTE_WRITE=true
APP_ACCESS_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# IA remota opcional para analisis textual.
DEEPSEEK_API_KEY=

# No importar WHISPER_COMMAND, WHISPER_MODEL, FFMPEG_COMMAND ni OLLAMA_BASE_URL:
# el procesado pesado corre en el ordenador con el worker local.
